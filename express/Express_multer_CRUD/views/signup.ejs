    <div class="signup-card">

        <h2>LinkedIn</h2>
        <p>Create your professional account</p>

        <!-- Profile Upload -->

        <div class="profile-upload">
            <label for="userProfile">
                <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" id="previewImg">
            </label>
            <p>Upload Profile</p>
        </div>

        <form action="/saveform" method="POST" enctype="multipart/form-data">

            <!-- Profile Photo -->
            <input type="file" id="userProfile" name="userProfile"  onchange="previewImage(event)">
             <!-- <input type="file" name="userProfile" id="userProfile"> -->

            <!-- Full Name -->
            <div class="input-box">
                <label for="userName">Full Name</label>
                <input type="text" id="userName" name="userName" placeholder="Enter your name" required>
            </div>

            <!-- Email -->
            <div class="input-box">
                <label for="userEmail">Email Address</label>
                <input type="email" id="userEmail" name="userEmail" placeholder="Enter your email" required>
            </div>

            <!-- Password -->
            <div class="input-box">
                <label for="userPass">Password</label>
                <input type="password" id="userPass" name="userPass" placeholder="Create a password" required>
            </div>

            <!-- Created Date -->
            <input type="hidden" id="createdAt" name="createdAt">

            <button type="submit">Create Account</button>

            <div class="login">
                Already have an account?
                <a href="#">Login</a>
            </div>

        </form>

    </div>

    <script>

        /* Image Preview */

        function previewImage(event) {
            const reader = new FileReader();

            reader.onload = function () {
                document.getElementById("previewImg").src = reader.result;
            }

            reader.readAsDataURL(event.target.files[0]);
        }

        /* Auto set created date */

        document.getElementById("createdAt").value = new Date().toISOString();

    </script>

</body>

