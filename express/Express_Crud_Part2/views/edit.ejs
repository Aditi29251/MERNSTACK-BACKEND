<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Form</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, aqua);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            background: white;
            padding: 35px;
            width: 350px;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .input-group {
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
        }

        .input-group label {
            margin-bottom: 5px;
            font-weight: 600;
        }

        .input-group input {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 14px;
        }

        .input-group input:focus {
            border-color: aqua;
            outline: none;
        }

        .checkbox {
            flex-direction: row;
            align-items: center;
            gap: 10px;
        }

        button {
            width: 100%;
            padding: 12px;
            border: none;
            background: aqua;
            color: white;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: aqua;
        }

        a {
            justify-content: center;
            text-transform: none;

        }
    </style>
</head>

<body>



    <div class="container">

        <a href="/view_products">view Products</a>

        <h2>Add Product</h2>

        <form action="/updateform/<%=data._id%>" method="post">

            <div class="input-group">
                <label>Product Name</label>
                <input type="text" id="productName" value="<%-data.productName%>" name="productName" placeholder="Enter product name" required>
            </div>

            <div class="input-group">
                <label>Product Price</label>
                <input type="number" id="productPrice" value="<%-data.productPrice%>" name="productPrice"
                    placeholder="Enter price">
            </div>

            <div class="input-group">
                <label>Product Quantity</label>
                <input type="number" id="productQuantity" value="<%-data.productQuantity%>" name="productQuantity"
                    placeholder="Enter quantity">
            </div>

            <div class="input-group checkbox"> <input type="checkbox" id="productInStock" name="productInStock" <%-data.productInStock ? "checked" : "" %>>
                     <label for="productInStock">In Stock</label>
           </div>


            <button type="submit">Update Product</button>

        </form>
    </div>

</body>

</html>