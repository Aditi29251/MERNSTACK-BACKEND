<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Table</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />


    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            padding: 40px;
        }

        .container {
            width: 80%;
            margin: auto;
        }

        h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        th {
            background: #2575fc;
            color: white;
            padding: 12px;
        }

        td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid #ddd;
        }

        tr:hover {
            background: #f1f1f1;
        }

        .instock {
            color: green;
            font-weight: bold;
        }

        .outstock {
            color: red;
            font-weight: bold;
        }
    </style>
</head>

<body>


    <a href="/">Add Products</a>

    <h2>Product List</h2>

    <div class="table-container">
        <table class="product-table">
            <thead>
                <tr>
                    <th>Product name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Status</th>
                    <th>Action</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <%data.map((val,index)=>{%>
                    <tr>
                        <td><%- val.productName%></td>
                        <td><%-val.productPrice%></td>
                        <td><%-val.productQuantity%></td>
                        <td class="outstock"><%-val.productInStock===true ? "In Stock" : "Out of stock"%></td>
                        <td><a onclick="return window.confirm('are you sure')" href="/deleteProduct/<%-val._id%>"><i class="fa fa-trash" style="font-weight:bold; color:red;"></a></i></td>
                        <td><a href="/edit/<%-val._id%>"><i class="fa fa-edit" style="font-weight:bold; color: green;"></i></a></td>
                    </tr>
                    
                    
                    <% })%>
                    <%if(data<=0){ %>
                        <tr>
                            <td colspan="5" style="font-weight: bold; text-align: center;">No product found</td>
                        </tr>

                        <%} %>
            </tbody>


        </table>

    </div>

</body>

</html>