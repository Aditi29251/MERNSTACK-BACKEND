<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Instagram Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      display: flex;
      background: #fafafa;
    }

    /* Sidebar */
    .sidebar {
      width: 250px;
      height: 100vh;
      border-right: 1px solid #ddd;
      padding: 20px;
      position: fixed;
      background: white;
    }

    .logo {
      font-size: 26px;
      font-weight: bold;
      margin-bottom: 30px;
    }

    .menu a {
      display: block;
      padding: 12px;
      margin: 5px 0;
      text-decoration: none;
      color: black;
      border-radius: 10px;
      transition: 0.3s;
    }

    .menu a:hover {
      background: #efefef;
    }

    /* Main */
    .main {
      margin-left: 260px;
      width: 55%;
      padding: 20px;
    }

    /* Stories */
    .stories {
      display: flex;
      gap: 15px;
      margin-bottom: 20px;
      overflow-x: auto;
    }

    .story {
      text-align: center;
    }

    .story img {
      width: 65px;
      height: 65px;
      border-radius: 50%;
      border: 2px solid #ff4d6d;
      padding: 2px;
    }

    .story p {
      font-size: 12px;
    }

    /* Post */
    .post {
      background: white;
      border: 1px solid #ddd;
      border-radius: 10px;
      margin-bottom: 20px;
    }

    .post-header {
      padding: 10px;
      font-weight: bold;
    }

    .post img {
      width: 100%;
      border-radius: 5px;
    }

    .post-actions {
      padding: 10px;
      font-size: 20px;
    }

    .post-caption {
      padding: 0 10px 10px;
    }

    /* Right Sidebar */
    .right {
      width: 25%;
      padding: 20px;
    }

    .profile {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }

    .profile img {
      width: 50px;
      border-radius: 50%;
    }

    .suggestions h4 {
      margin-bottom: 10px;
    }

    .suggestions div {
      margin-bottom: 10px;
      font-size: 14px;
    }

    /* Logout */
    .logout {
      margin-top: 30px;
      display: block;
      color: red;
      text-decoration: none;
    }

  </style>
</head>

<body>
 
   
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="logo">Instagram</div>
<a href="/"><button>Home page</button></a>
    <div class="menu">
      <a href="#">🏠 Home</a>
      <a href="#">🔍 Search</a>
      <a href="#">➕ Create</a>
      <a href="#">❤️ Notifications</a>
      <a href="#">👤 Profile</a>
      <a href="/msg">👤 Message</a>
    </div>

    <a href="/" class="logout">🚪 Logout</a>
  </div>

  <!-- Main Feed -->
  <div class="main">

    <!-- Stories -->
    <div class="stories">
      <div class="story">
        <img src="https://i.pravatar.cc/65?img=1">
        <p>You</p>
      </div>

      <div class="story">
        <img src="https://i.pravatar.cc/65?img=2">
        <p>Riya</p>
      </div>

      <div class="story">
        <img src="https://i.pravatar.cc/65?img=3">
        <p>Rahul</p>
      </div>

      <div class="story">
        <img src="https://i.pravatar.cc/65?img=4">
        <p>Aman</p>
      </div>
    </div>

    <!-- Post 1 -->
    <div class="post">
      <div class="post-header">aditi</div>
      <img src="https://picsum.photos/500/400">
      <div class="post-actions">❤️ 💬 ➤</div>
      <div class="post-caption"><b>aditi</b> Enjoying the view 🌄</div>
    </div>

    <!-- Post 2 -->
    <div class="post">
      <div class="post-header">riya</div>
      <img src="https://picsum.photos/500/401">
      <div class="post-actions">❤️ 💬 ➤</div>
      <div class="post-caption"><b>riya</b> Weekend vibes ✨</div>
    </div>

  </div>

  <!-- Right Sidebar -->
  <div class="right">
    <div class="profile">
      <img src="https://i.pravatar.cc/50">
      <div>
        <b>Aditi</b><br>
        <small>Welcome back</small>
      </div>
    </div>

    <div class="suggestions">
      <h4>Suggestions for you</h4>
      <div>rahul_123</div>
      <div>travel_girl</div>
      <div>fitness_pro</div>
    </div>
  </div>

</body>
</html>